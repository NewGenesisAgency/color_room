@startuml ColorRoom_Classes
skinparam classAttributeIconSize 0
skinparam classFontStyle bold
skinparam classBackgroundColor #EFF6FF
skinparam classBorderColor #2563EB
skinparam classArrowColor #475569
hide circle
hide methods

title ColorRoom - Classes principales

class Salle {
  numero : int
}

class Dalle {
  id : int
  type : rouge | bleu
}

class Jeu {
  id : string
  name : string
}

class Utilisateur {
  id : string
  name : string
}

class Score {
  game : string
  points : int
}

class SessionMP {
  code : string
  status : string
}

Salle "1" *-- "21" Dalle
Utilisateur "1" -- "*" Score
SessionMP "1" *-- "2..4" Utilisateur
SessionMP --> Jeu
Jeu --> Dalle : pilote

@enduml
