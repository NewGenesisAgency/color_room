@startuml ColorRoom_Seq_IA
skinparam sequenceArrowColor #7C3AED
skinparam sequenceParticipantBackgroundColor #F5F3FF
skinparam sequenceParticipantBorderColor #7C3AED

title ColorRoom - Génération IA d'un jeu

actor Enseignant
participant "Éditeur" as ED
participant "API /ai" as API
participant "Ollama" as AI
database "SQLite" as DB

Enseignant -> ED : décrit le jeu (texte)
ED -> API : prompt
API -> AI : génère
AI --> API : JSON du jeu
API -> DB : sauvegarde
API --> ED : jeu prêt

@enduml
