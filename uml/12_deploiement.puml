@startuml ColorRoom_Deploiement
skinparam nodeBackgroundColor #FEF9C3
skinparam nodeBorderColor #CA8A04
skinparam componentBackgroundColor #EFF6FF
skinparam componentBorderColor #2563EB
skinparam arrowColor #475569

title ColorRoom - Déploiement

node "Raspberry Pi" {
  node "Docker" {
    component "App Next.js" as APP
    component "Ollama" as AI
  }
  component "supervision.exe" as SUP
}

node "Clients Wi-Fi" as CLI
node "Dalles LED" as LED
node "CS-160" as CS

CLI --> APP
APP --> AI
APP --> SUP
APP --> CS
SUP --> LED

@enduml
