@startuml ColorRoom_Activite_Remap
skinparam activityBackgroundColor #EFF6FF
skinparam activityBorderColor #2563EB
skinparam activityDiamondBackgroundColor #FEF9C3
skinparam activityDiamondBorderColor #CA8A04
skinparam activityArrowColor #475569

title ColorRoom - Envoi couleur à une dalle

start
:couleur RGB + id dalle;
if (dalle de type bleu ?) then (oui)
  :remap canaux rouge -> bleu;
else (non)
  :canaux inchangés;
endif
:POST /api/supervision;
:dalle allumée;
stop

@enduml
