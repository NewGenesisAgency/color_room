@startuml ColorRoom_Classes_Editeur
skinparam classAttributeIconSize 0
skinparam classFontStyle bold
skinparam classBackgroundColor #FAF5FF
skinparam classBorderColor #7C3AED
skinparam classArrowColor #6D28D9
hide circle
hide methods

title ColorRoom - Modèle de l'éditeur (Blueprint)

class GameDoc {
  id : string
  name : string
}

class Node {
  id : string
  kind : string
}

class Edge {
  from : string
  to : string
  kind : exec | data
}

class UIComponent {
  kind : string
}

GameDoc "1" *-- "*" Node
GameDoc "1" *-- "*" Edge
GameDoc "1" *-- "*" UIComponent
Edge --> Node : relie

@enduml
